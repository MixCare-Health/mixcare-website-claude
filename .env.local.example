# Sanity.io — copy this file to .env.local and fill in your values

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google reCAPTCHA v2 — get keys at https://www.google.com/recaptcha/admin/create
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key   # public — safe to expose
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key            # server-only — never expose

# Resend email API — get key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx                   # server-only — never expose

# Get these from https://www.sanity.io/manage → your project → Settings → API

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Write token — required for running the seed script (scripts/seed-sanity.ts) only
# Create a token at: sanity.io/manage → your project → API → Tokens → Add API token (Editor)
SANITY_API_TOKEN=your_write_token_here
